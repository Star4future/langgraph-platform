# LangGraph Platform — Environment Configuration
# Copy to .env and fill values

# ────────────────────────────────────────────────
# Vertical Selection
# Which vertical to load. Must match a folder in verticals/
# ────────────────────────────────────────────────
VERTICAL=education

# ────────────────────────────────────────────────
# LLM Provider
# Leave OPENAI_API_KEY blank to run in MOCK_MODE (free demo, no real LLM calls)
# ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
TRIAGE_MODEL=gpt-4o-mini
RESOLVER_MODEL=gpt-4o-mini
SUPERVISOR_MODEL=gpt-4o-mini

# ────────────────────────────────────────────────
# Behavioural Knobs
# ────────────────────────────────────────────────
QUALITY_THRESHOLD=0.7
TRIAGE_CONFIDENCE_FLOOR=0.5
MAX_RETRY_COUNT=2

# ────────────────────────────────────────────────
# Security
# ────────────────────────────────────────────────
# CORS origins (comma-separated). Defaults to "*" which is fine for local dev
# but must be set to your actual domain(s) in any real deployment.
# CORS_ORIGINS=https://aceachievers.com.au,https://demo.yourbrand.com.au

# ────────────────────────────────────────────────
# Logging / Observability
# ────────────────────────────────────────────────
LOG_LEVEL=INFO
# LANGSMITH_API_KEY=ls__xxxxxxxxxxxxxxxxxxxx
# LANGSMITH_PROJECT=langgraph-platform-prod
