# AceAchievers Deployment — Environment Variables
# Copy to .env (local) or set in Vercel project settings (production)

# Vertical (always education for AceAchievers)
VERTICAL=education

# LLM — leave OPENAI_API_KEY blank for MOCK_MODE (public Vercel deploys keep this blank)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# Behaviour knobs (defaults usually fine)
QUALITY_THRESHOLD=0.7
MAX_RETRY_COUNT=2
TRIAGE_CONFIDENCE_FLOOR=0.5

LOG_LEVEL=INFO
