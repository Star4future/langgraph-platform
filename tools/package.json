{
  "name": "langgraph-platform-sse-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed, zod-validated TypeScript SSE client and Node CLI for the LangGraph Platform agent event stream.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:web": "esbuild web-entry.ts --bundle --format=esm --platform=browser --target=es2020 --outfile=../web/sse-client.mjs",
    "cli": "tsx sse-cli.ts",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
