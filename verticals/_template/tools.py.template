@tool
def escalate_to_human(reason: str, priority: str = "standard") -> dict:
    """Flag a request for human review.

    Use when the customer requests something the AI shouldn't decide
    (e.g. policy edge case, complaint, high-value transaction).
    """
    return {
        "escalated": True,
        "ticket_id": f"TKT-{int(datetime.now().timestamp()) % 100000}",
        "reason": reason,
        "priority": priority,
        "expected_response_hours": 24,
    }


